thon","executable":true,"value":"import cdsapi\n\ndataset = \"reanalysis-era5-single-levels-monthly-means\"\nrequest = {\n    \"product_type\": [\"monthly_averaged_reanalysis\"],\n    \"variable\": [\"total_precipitation\"],\n    \"year\": [\n       \"1997\", \"1987\", \"1982\", \"2023\", \"1972\", \"2002\", \"1991\", \"1992\", \"1957\", \"2019\",\n       \"1955\", \"1950\", \"1975\", \"1999\", \"1971\", \"1974\", \"1988\", \"1956\", \"2022\", \"2000\"\n    ],\n    \"month\": [\n        \"12\", \"01\", \"02\"\n    ],\n    \"time\": [\"00:00\"],\n    \"data_format\": \"grib\",\n    \"download_format\": \"unarchived\"\n}\n\nclient = cdsapi.Client()\nclient.retrieve(dataset, request).download()\n","key":"j9GIR1t5Vk"},{"type":"outputs","id":"CU04mXIDng-VmNsV-AT1z","children":[],"key":"bpw5xaf1g7"}],"key":"LblK9k281P"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Again using my library ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"l9WTLJkk7s"},{"type":"strong","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"climavis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MyAjZbvDs8"}],"key":"yyZyKplQ5b"},{"type":"text","value":", we can do some visualization:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ACcrBfyAuk"}],"key":"eWpESHkSEN"}],"key":"yRVwmdJVjo"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import climavis as cv\nimport numpy as np\n\ndata_path = {\n    \"tp\" : \"data/precipitation.grib\" \n}\n\nds_tp = cv.DataSet(\"total precipitation\", data_paths = data_path, time_steps=60, unit='m')\n\nds_tp.getAnomoly()\n\nelnino = [1997,1987,1982, 2023, 1972, 2002, 1991, 1992, 1957,2019]\nlanina = [1955, 1950, 1975, 1999, 1971, 1974, 1988, 1956, 2022, 2000]\n\nds_tp.averageOverTime(new_time_unit='years', new_time_steps=20)\n\nelnino_tp, lanina_tp = ds_tp.groupByTimeGroup(group1 = elnino, group2=lanina, group1_name = \"El Niño\", group2_name = \"La Niña\", time_unit = 'years')\n\nvis_param_elnino = {\n    \"task_name\" : \"El_nino_tp\",\n    \"data_set\" : elnino_tp, \n    \"outputs_dir\" : \"output\"\n}\n\nvis_param_lanina = {\n    \"task_name\" : \"La_nina_tp\",\n    \"data_set\" : lanina_tp, \n    \"outputs_dir\" : \"output\"\n}\n\nlevels = np.array([-0.04, -0.03, -0.02,-0.001, -0.0005, -0.0004, -0.0003, -0.0002, -0.0001, -1e-5, -1e-5/2])\nlevels = np.concatenate([levels, -levels[::-1]])\nvis = cv.Visualize(**vis_param_elnino)\nvis.populate_frame(title=\"ENSO Total Precipitation Anomoly Composite\", colormap='bwr', levels=levels)\n\nvis = cv.Visualize(**vis_param_lanina)\nvis.populate_frame(title=\"ENSO Total Precipitation Anomoly Composite\", colormap='bwr', levels=levels)","key":"RyWFHAF0O4"},{"type":"outputs","id":"byHLzqVCb9k56uug-OhqY","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"[Visualize-LOG] Directory 'output/El_nino_tp' already exists\n[Visualize-LOG] Directory 'output/El_nino_tp/frame' already exists\n[Visualize-LOG] Directory 'output/El_nino_tp/animation' already exists\n[Visualize LOG] Plotting frame in scalar mode\n"},"children":[],"key":"JYVFY37aWA"},{"type":"output","jupyter_data":{"name":"stderr","output_type":"stream","text":"100%|██████████| 1/1 [00:02<00:00,  2.28s/it]\n"},"children":[],"key":"VLNZUWkREA"},{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"[Visualize-LOG] Directory 'output/La_nina_tp' already exists\n[Visualize-LOG] Directory 'output/La_nina_tp/frame' already exists\n[Visualize-LOG] Directory 'output/La_nina_tp/animation' already exists\n[Visualize LOG] Plotting frame in scalar mode\n"},"children":[],"key":"kdk9QdhM4L"},{"type":"output","jupyter_data":{"name":"stderr","outpu